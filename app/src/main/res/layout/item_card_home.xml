<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- ─── Left: Item Image with Flag overlay ─── -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivItemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:src="@drawable/ic_placeholder_item"
                android:contentDescription="@string/cd_item_image" />

            <!-- Status Flag: LOST / FOUND / RESOLVED -->
            <TextView
                android:id="@+id/tvItemFlag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:text="@string/flag_lost"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="@font/poppins_bold"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/bg_flag_lost" />
            <!--
                bg_flag_lost  → red   (#E24B4A), corners: bottomRight only
                bg_flag_found → green (#1D9E75), corners: bottomRight only
                bg_flag_resolved → gray (#888888), corners: bottomRight only
                Switch drawable via Java: ivFlag.setBackgroundResource(R.drawable.bg_flag_found)
            -->
        </FrameLayout>

        <!-- ─── Right: Item Details ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="10dp"
            android:justificationMode="inter_word">

            <!-- Item Title -->
            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_item_title"
                android:fontFamily="@font/poppins_bold"
                android:includeFontPadding="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Category -->
            <TextView
                android:id="@+id/tvItemCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/placeholder_category"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/poppins_medium"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Description snippet -->
            <TextView
                android:id="@+id/tvItemDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/placeholder_desc"
                android:textSize="12sp"
                android:textColor="@color/hint_color"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Bottom Row: Location + Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Location Pin Icon + Text -->
                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_location_pin"
                    app:tint="@color/color_accent" />

                <TextView
                    android:id="@+id/tvItemLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:text="@string/placeholder_location"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_medium"
                    android:includeFontPadding="false"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Time -->
                <TextView
                    android:id="@+id/tvItemTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_time"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_regular"
                    android:includeFontPadding="false"
                    android:textColor="@color/text_hint" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>