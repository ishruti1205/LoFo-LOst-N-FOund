<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ─── FIXED HEADER (Top Bar + Search + Tabs) ─── -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/color_topbar">

        <!-- Top Row -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <!-- App Name "LoFo" -->
            <LinearLayout
                android:id="@+id/layoutAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:id="@+id/ivAppLogo"
                    android:layout_width="46dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/app_icon_crop"
                    android:gravity="center_vertical"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:id="@+id/tvAppName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name_first_half"
                    android:textSize="46sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:includeFontPadding="false"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tvAppName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name_second_half"
                    android:textSize="46sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_accent" />

            </LinearLayout>

            <!-- Right Icons Group -->
            <LinearLayout
                android:id="@+id/layoutIcons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:spacing="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Filter Icon -->
                <!--                <ImageView-->
                <!--                    android:id="@+id/ivFilter"-->
                <!--                    android:layout_width="36dp"-->
                <!--                    android:layout_height="36dp"-->
                <!--                    android:padding="7dp"-->
                <!--                    android:src="@drawable/ic_filter"-->
                <!--                    android:contentDescription="@string/cd_filter"-->
                <!--                    app:tint="@color/icon_tint"-->
                <!--                    android:background="@drawable/bg_icon_btn_round"/>-->

                <!-- Messages Icon with Badge -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp">

                    <ImageView
                        android:id="@+id/ivMessages"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_chat_bubble"
                        android:contentDescription="@string/cd_messages"
                        app:tint="@color/icon_tint"
                        android:background="@drawable/bg_icon_btn_round"/>

                    <TextView
                        android:id="@+id/tvMessagesBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="0"
                        android:textSize="8sp"
                        android:textColor="@color/white"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_badge_red"
                        android:visibility="visible" />
                </FrameLayout>

                <!-- Notifications Icon with Badge -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp">

                    <ImageView
                        android:id="@+id/ivNotifications"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_notifications"
                        android:contentDescription="@string/cd_notifications"
                        app:tint="@color/icon_tint"
                        android:background="@drawable/bg_icon_btn_round"/>

                    <TextView
                        android:id="@+id/tvNotifBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="0"
                        android:textSize="8sp"
                        android:textColor="@color/white"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_badge_red"
                        android:visibility="visible" />
                </FrameLayout>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Search Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSearch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="@color/color_searchbar"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/icon_tint_muted" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="@string/hint_search"
                        android:textColorHint ="@color/hint_color"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:background="@null"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:singleLine="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Filter Button -->
            <ImageView
                android:id="@+id/ivSearchFilter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:padding="8dp"
                android:src="@drawable/ic_tune"
                app:tint="@color/icon_tint"
                android:background="@drawable/bg_icon_btn_round"
                android:contentDescription="@string/cd_search_filter" />


        </LinearLayout>

        <!-- Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/color_topbar"
            app:tabPaddingStart="5dp"
            app:tabPaddingEnd="5dp"
            app:tabIndicatorColor="@color/color_accent"
            app:tabIndicatorHeight="2.5dp"
            app:tabSelectedTextColor="@color/color_accent"
            app:tabTextColor="@color/color_tab_unselected"
            app:tabTextAppearance="@style/TabTextAppearance"
            app:tabMode="fixed"
            app:tabGravity="fill">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_all" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_lost" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_found" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_resolved" />
        </com.google.android.material.tabs.TabLayout>

    </LinearLayout>

    <!-- ─── SCROLLABLE AREA ─── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_page"
            android:clipToPadding="false"
            android:paddingHorizontal="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="18dp"/>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_empty_box"
                app:tint="@color/icon_tint_muted"
                android:alpha="0.5" />

            <TextView
                android:id="@+id/tvEmptyMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/empty_no_items"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_regular"
                android:includeFontPadding="false"
                android:textColor="@color/text_secondary"
                android:gravity="center" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>