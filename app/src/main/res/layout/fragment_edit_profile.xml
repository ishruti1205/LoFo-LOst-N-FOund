<?xml version="1.0" encoding="utf-8"?>
<!--
    Edit Profile screen.
    - Three accordion sections: tap header row to expand, chevron rotates 180°.
    - All sections start COLLAPSED so the screen is clean on open.
    - windowSoftInputMode=adjustResize on MainActivity is enough; the NestedScrollView
      handles scrolling the focused field above the keyboard automatically because
      android:fillViewport="true" + layout_weight="1" make the scroll view fill
      the available space above the keyboard.
-->
<LinearLayout
    android:id="@+id/rootEditProfile"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- ─── Top Bar ─── -->
    <LinearLayout
        android:id="@+id/editProfileTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_topbar"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivEditProfileBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_chevron_left"
            app:tint="@color/white"
            android:background="@drawable/bg_icon_btn_round"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/option_edit_profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold"
            android:includeFontPadding="false"
            android:textColor="@color/white" />
    </LinearLayout>

    <!--
        NestedScrollView with layout_weight="1" takes all remaining vertical space.
        When the keyboard rises, the activity shrinks (adjustResize), this view
        shrinks to match, and the focused field scrolls into view automatically.
    -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/editProfileScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- ══════════════════════════════════════════
                 SECTION 1 — Display Name
                 ══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_topbar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Accordion header row -->
                    <LinearLayout
                        android:id="@+id/headerName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/color_accent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="@string/section_display_name"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"
                            android:includeFontPadding="false"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/chevronName"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_down"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/text_hint" />
                    </LinearLayout>

                    <!-- Collapsible content -->
                    <LinearLayout
                        android:id="@+id/layoutNameContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="@color/color_searchbar"
                            android:layout_marginBottom="14dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilName"
                            style="@style/LoFo.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_display_name">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                style="@style/LoFo.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:inputType="textCapWords"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:imeOptions="actionDone"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveName"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/btn_save_name"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/color_accent"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════════════════
                 SECTION 2 — Change Email
                 ══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_topbar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerEmail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_email"
                            app:tint="@color/color_accent"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="@string/section_change_email"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"
                            android:includeFontPadding="false"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/chevronEmail"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_down"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/text_hint" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutEmailContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="@color/color_searchbar"
                            android:layout_marginBottom="14dp" />

                        <!-- Info note -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_info_note"
                            android:padding="10dp"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_marginTop="1dp"
                                android:src="@drawable/ic_info"
                                app:tint="@color/color_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/msg_email_verify_info"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_regular"
                                android:justificationMode="inter_word"
                                android:includeFontPadding="false"
                                android:textColor="@color/icon_tint"
                                android:lineSpacingMultiplier="1.1" />
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCurrentPasswordEmail"
                            style="@style/LoFo.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_current_password"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/hint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCurrentPasswordEmail"
                                style="@style/LoFo.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:inputType="textPassword"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:imeOptions="actionNext"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilNewEmail"
                            style="@style/LoFo.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/hint_new_email">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNewEmail"
                                style="@style/LoFo.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:inputType="textEmailAddress"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:imeOptions="actionDone"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveEmail"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/btn_save_email"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/color_accent"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════════════════
                 SECTION 3 — Change Password
                 ══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/color_topbar">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/color_accent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:text="@string/section_change_password"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"
                            android:includeFontPadding="false"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/chevronPassword"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_down"
                            android:clickable="true"
                            android:focusable="true"
                            app:tint="@color/text_hint" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutPasswordContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:background="@color/color_searchbar"
                            android:layout_marginBottom="14dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilCurrentPasswordPwd"
                            style="@style/LoFo.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_current_password"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/hint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etCurrentPasswordPwd"
                                style="@style/LoFo.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:inputType="textPassword"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:imeOptions="actionNext"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilNewPassword"
                            style="@style/LoFo.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/hint_new_password"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/hint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etNewPassword"
                                style="@style/LoFo.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:inputType="textPassword"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:imeOptions="actionNext"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilConfirmPassword"
                            style="@style/LoFo.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/hint_confirm_password"
                            app:endIconMode="password_toggle"
                            app:endIconTint="@color/hint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etConfirmPassword"
                                style="@style/LoFo.TextInputEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:inputType="textPassword"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:imeOptions="actionDone"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSavePassword"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/btn_save_password"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/white"
                            app:backgroundTint="@color/color_accent"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>